# Sunucu için şablon: Laravel köküne `.env` adıyla kopyalayın, değerleri doldurun.
# Yerelde: cp deploy/.env.hosting.example .env

APP_NAME="CRN Baca"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://alanadiniz.com

APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr
APP_FAKER_LOCALE=tr_TR

APP_MAINTENANCE_DRIVER=file

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=KULLANICI_VERITABANI
DB_USERNAME=KULLANICI_ADI
DB_PASSWORD=VERITABANI_SIFRESI

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@alanadiniz.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# crn-install.php için zorunlu (uzun rastgele dize); kurulumdan sonra .env'den silin
CRN_INSTALL_KEY=DEGISTIR_UZUN_RASTGELE_ANAHTAR

# İsteğe bağlı: ilk admin (boş bırakılırsa seed: admin@crn.local / password)
# CRN_ADMIN_EMAIL=yonetici@alanadiniz.com
# CRN_ADMIN_PASSWORD=
# CRN_ADMIN_NAME=Yönetici
