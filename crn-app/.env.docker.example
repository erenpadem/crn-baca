# Docker ortamı için örnek - docker-compose kullanırken .env olarak kopyalayın
APP_NAME="CRN Baca"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr
APP_FAKER_LOCALE=tr_TR

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
